# Neon PostgreSQL connection string.
# Used by:
#   - generate_dashboard.py (live dashboard metrics)
#   - common/pdf_extract.py (idempotent "skip if already in Neon with text"
#     check used by every scraper that extracts PDFs)
# Without this, scrapers still work — they just re-extract PDFs for records
# that are already in the database.
NEON_DATABASE_URL=postgresql://user:password@ep-XXXXX.region.aws.neon.tech/dbname?sslmode=require

# ── Source-specific API keys ──
# LegiScan — all 50 US states + Congress bills with full text.
# Free tier: 30,000 queries/month. Register at https://legiscan.com/legiscan-register
# Used by: sources/US/LegiScan/bootstrap.py
LEGISCAN_API_KEY=

# Opt-out flag: set to 1 to disable opendataloader-pdf (markdown extraction)
# and force common/pdf_extract.py to use pdfplumber/pypdf fallbacks only.
# Useful on hosts without Java or for CI debugging.
# OPENDATALOADER_DISABLED=1
